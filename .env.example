# Firebase Client Config
# Get these from: Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=figgg-c2c8f
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Calendar sync URLs (comma-separated, no spaces around commas)
# These contain auth tokens — never commit actual values to the repo
VITE_CALENDAR_URLS=

# ──────────────────────────────────────────────────
# MANUAL SETUP STEPS (not env vars — do these once)
# ──────────────────────────────────────────────────
#
# 1. Copy this file to .env.local and fill in the values above
#    cp .env.example .env.local
#
# 2. Set the Anthropic API key for Cloud Functions:
#    firebase functions:secrets:set ANTHROPIC_API_KEY
#
# 3. Create a Firebase Auth user (email/password) in the Console:
#    Firebase Console > Authentication > Add user
#
# 4. Deploy everything for the first time:
#    npm run build
#    firebase deploy
#
# 5. For GitHub Actions CI/CD, add these repository secrets:
#    - FIREBASE_SERVICE_ACCOUNT  (JSON key from Firebase Console > Project Settings > Service Accounts > Generate new private key)
#    - VITE_FIREBASE_API_KEY
#    - VITE_FIREBASE_AUTH_DOMAIN
#    - VITE_FIREBASE_PROJECT_ID
#    - VITE_FIREBASE_STORAGE_BUCKET
#    - VITE_FIREBASE_MESSAGING_SENDER_ID
#    - VITE_FIREBASE_APP_ID
#    - VITE_FIREBASE_MEASUREMENT_ID
